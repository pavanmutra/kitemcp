{
  "name": "kitemcp-portfolio-intelligence",
  "version": "1.1.0",
  "description": "AI-powered portfolio intelligence for Indian equity markets (NSE/BSE)",
  "main": "src/run_daily.js",
  "scripts": {
    "start": "node src/run_daily.js",
    "lint": "eslint src/*.js src/**/*.js --ignore-pattern '**/*.test.js' --ignore-pattern 'src/__tests__/**' --ignore-pattern 'src/public/**'",
    "lint:fix": "eslint src/*.js src/**/*.js --ignore-pattern '**/*.test.js' --ignore-pattern 'src/__tests__/**' --ignore-pattern 'src/public/**' --fix",
    "report": "node src/create_master_markdown.js",
    "export": "node src/create_portfolio_export.js",
    "scan": "node src/scan_opportunities.js",
    "deepvalue": "node src/convert_deep_value.js",
    "commodities": "node src/fetch_commodities.js",
    "login": "node src/kite_login.js",
    "login:status": "node src/kite_login.js status",
    "login:open": "node src/kite_login.js open",
    "export:weekly": "node src/create_weekly_export.js",
    "check": "node src/check_gates.js",
    "status": "node src/check_gates.js",
    "dashboard": "node src/dashboard.js",
    "web": "node src/server.js",
    "dev": "node src/server.js",
    "refresh": "node src/scripts/refresh_live_prices.js",
    "test": "node node_modules/jest/bin/jest.js src/__tests__ --no-coverage --forceExit && node src/test_runner.js",
    "test:unit": "node node_modules/jest/bin/jest.js src/__tests__ --no-coverage --forceExit",
    "test:integration": "node src/test_runner.js",
    "test:api": "node src/test_runner.js --api",
    "help": "node -e \"console.log('\\nAvailable Commands:\\n npm start\\t\\tRun full daily workflow\\n npm run check\\t\\tCheck gate status\\n npm run dashboard\\tQuick CLI portfolio summary\\n npm run report\\t\\tGenerate daily Markdown report\\n npm run export\\t\\tGenerate portfolio Excel\\n npm run refresh\\t\\tRefresh live prices via AI agent\\n npm run web\\t\\tStart web dashboard (auto-opens browser)\\n npm test\\t\\tRun unit + integration tests (all suites)\\n npm run test:unit\\tUnit tests only (116 tests)\\n npm run test:integration\\tIntegration tests only (53 tests)\\n')\"",
    "prepare": "husky"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "jest --bail --findRelatedTests"
    ],
    "src/*.js": [
      "eslint --fix",
      "jest --bail --findRelatedTests"
    ]
  }
}
